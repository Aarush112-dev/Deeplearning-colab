\n","          action: 'append',\n","          file: file.name,\n","          data: base64,\n","        },\n","      };\n","\n","      let percentDone = fileData.byteLength === 0 ?\n","          100 :\n","          Math.round((position / fileData.byteLength) * 100);\n","      percent.textContent = `${percentDone}% done`;\n","\n","    } while (position < fileData.byteLength);\n","  }\n","\n","  // All done.\n","  yield {\n","    response: {\n","      action: 'complete',\n","    }\n","  };\n","}\n","\n","scope.google = scope.google || {};\n","scope.google.colab = scope.google.colab || {};\n","scope.google.colab._files = {\n","  _uploadFiles,\n","  _uploadFilesContinue,\n","};\n","})(self);\n","</script> "]},"metadata":{}},{"output_type":"stream","name":"stdout","text":["Saving car.csv to car.csv\n"]}]},{"cell_type":"code","source":["data = pd.read_csv(\"car.csv\")\n","data.columns = [\"buying\",\"maint\",\"doors\",\"persons\",\"lug_boot\",\"safety\",\"class\"]\n","data[\"doors\"] = data[\"doors\"].replace(\"5more\",\"5\")\n","data[\"persons\"] = data[\"persons\"].replace(\"more\",\"5\")"],"metadata":{"id":"9hXHOdnOPFwK","executionInfo":{"status":"ok","timestamp":1765017657048,"user_tz":0,"elapsed":5,"user":{"displayName":"Aarush Menon","userId":"00117871425621944905"}}},"execution_count":5,"outputs":[]},{"cell_type":"code","source":["from sklearn.preprocessing import LabelEncoder\n","le = LabelEncoder()\n","data[\"buying\"] = le.fit_transform(data[\"buying\"])\n","data[\"maint\"] = le.fit_transform(data[\"maint\"])\n","data[\"doors\"] = le.fit_transform(data[\"doors\"])\n","data[\"persons\"] = le.fit_transform(data[\"persons\"])\n","data[\"lug_boot\"] = le.fit_transform(data[\"lug_boot\"])\n","data[\"safety\"] = le.fit_transform(data[\"safety\"])\n","data[\"class\"] = le.fit_transform(data[\"class\"])\n","\n","x_data = data[[\"maint\",\"doors\",\"persons\",\"lug_boot\",\"safety\",\"class\"]]"],"metadata":{"id":"EQPC8t95PMIh","executionInfo":{"status":"ok","timestamp":